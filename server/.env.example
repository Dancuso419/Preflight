# GitHub API token — increases rate limit from 60 to 5000 req/hr
# Generate at: https://github.com/settings/tokens (no scopes needed for public repos)
GITHUB_API_TOKEN=

# Gemini API key — get from https://aistudio.google.com/apikey
GEMMINI_API_KEY=

# Monad RPC endpoints (defaults work for testnet)
MONAD_RPC_URL_TESTNET=https://testnet-rpc.monad.xyz
MONAD_RPC_URL_MAINNET=https://rpc.monad.xyz

# Backend signer wallet private key — mints attestation badges on Monad
# Must hold MON for gas. Generate with: cast wallet new
BACKEND_SIGNER_PRIVATE_KEY=

# Deployed PreFlightAttestation contract address on Monad testnet
ATTESTATION_CONTRACT_ADDRESS=0x659A05Bab409E6Ccb76a715c9167d8A0344A4897
