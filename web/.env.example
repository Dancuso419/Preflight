# Backend API URL (set to your Render backend URL in production)
VITE_API_URL=http://localhost:3001

# WalletConnect project ID — get from https://cloud.walletconnect.com
# Optional: app works without it for injected wallets (MetaMask etc.)
VITE_WALLETCONNECT_PROJECT_ID=

# Monad testnet RPC (optional override)
VITE_MONAD_RPC_TESTNET=https://testnet-rpc.monad.xyz
